# === Gradle ===
.gradle/
build/
# Wrapper 本体は追跡する（下の除外に引っかからないよう明示）
!gradle/wrapper/gradle-wrapper.jar

# === Java ===
*.class
*.log
hs_err_pid*
replay_pid*

# === Spring Boot ===
*.original

# === IDE ===
.idea/
*.iml
*.ipr
*.iws
.vscode/
.settings/
.project
.classpath
bin/

# === macOS ===
.DS_Store

# === Claude Code（ステアリングは追跡、実行時ログ/ローカル設定は除外）===
.claude/stop-check.log
.claude/settings.local.json

# === LocalStack / infra 実行時データ ===
.localstack/
volume/

# === Terraform（M8）===
# state は平文で秘密を含むため絶対に追跡しない
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl  # ※ 追跡したくなったらこの行を削除（通常はコミット推奨だが本PoCでは当面除外）
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# tfvars は秘密が入りやすいので除外。共有用サンプルは *.example として追跡する
*.tfvars
*.tfvars.json
!*.tfvars.example

# === 秘密・資格情報（混入防止）===
.env
.env.*
!.env.example
*.pem
*.key
*_rsa
*_rsa.pub
.aws/
aws-credentials*
credentials
*.p12
*.pfx
